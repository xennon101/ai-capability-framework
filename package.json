  "scripts": {
    "archive:source": "node scripts/create-source-archive.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run check:generated && npm run build && npm run typecheck && npm run lint && npm test && npm run validate && npm run conformance && npm run gate:examples && npm run docs:build && npm run check:package && npm run check:workspace-public",
    "check:docs": "node scripts/check-docs.mjs",
    "check:generated": "node scripts/check-generated.mjs",
    "check:package": "npm run build && npm run check:package:contents && npm run check:package-public && npm run check:release-install",
    "check:package:contents": "node scripts/check-package.mjs",
    "check:package-public": "node scripts/check-package-public.mjs",
    "check:public": "npm run check:package-public && npm run check:workspace-public && npm run check:secrets",
    "check:optional": "vitest run src/__tests__/aws src/__tests__/mcp-server src/__tests__/promptfoo src/__tests__/langfuse src/__tests__/evalops src/__tests__/openai-agents src/__tests__/providers/anthropic src/__tests__/providers/gemini src/__tests__/providers/ai-sdk src/__tests__/providers/langchain src/__tests__/providers/mcp src/__tests__/providers/semantic-kernel src/__tests__/providers/conformance src/__tests__/conformance",
    "check:providers": "vitest run src/__tests__/providers",
    "check:providers:live": "npm run test:anthropic:live && npm run test:gemini:live && npm run test:ai-sdk:live && npm run test:langchain:live",
    "check:providers:mock": "npm run test:anthropic:mock && npm run test:gemini:mock && npm run test:ai-sdk:mock && npm run test:langchain:mock && npm run test:semantic-kernel && npm run test:mcp-provider && npm run test:providers:conformance && npm run test:conformance",
    "check:release": "npm run check && npm run check:optional && npm pack --dry-run --json",
    "check:certification": "npm run check:generated && npm run build && npm run typecheck && npm run lint && npm test && npm run validate && npm run conformance && npm run gate:examples && npm run docs:build && npm run check:package && npm run check:public && npm run check:runtime && npm run check:optional && npm run check:providers:mock && npm pack --dry-run --json && node scripts/check-certification.mjs",
    "check:release:providers": "npm run check && npm run check:providers:mock && npm run check:release-install && npm pack --dry-run --json",
    "check:release-install": "node scripts/check-release-install.mjs",
    "check:release-source": "npm run check:workspace-public && npm run check:git-clean && npm run check:source-archive",
    "check:runtime": "vitest run src/__tests__/runtime src/__tests__/openai src/__tests__/observability src/__tests__/evals-live src/__tests__/examples",
    "check:git-clean": "node scripts/check-git-clean.mjs",
    "check:source-archive": "node scripts/check-source-archive.mjs",
    "check:workspace-public": "node scripts/check-workspace-public.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "conformance": "node dist/cli.js conformance run examples --format text",
    "docs:api": "typedoc --options typedoc.json",
    "docs:build": "npm run docs:api && npm run check:docs",
    "gate:examples": "node dist/cli.js gate examples --env production",
    "generate:types": "node scripts/generate-types.mjs",
    "inspect": "npm run build --silent && node dist/cli.js inspect examples",
    "lint": "node scripts/check-repo-lint.mjs",
    "skills:validate": "npm --prefix agent-skills run validate",
    "skills:test": "npm --prefix agent-skills run test",
    "skills:check": "npm --prefix agent-skills run check",
    "skills:index": "npm --prefix agent-skills run index",
    "test": "npm run build --silent && vitest run",
    "test:openai:live": "vitest run src/__tests__/openai-live",
    "test:aws": "vitest run src/__tests__/aws",
    "test:aws:live": "vitest run src/__tests__/aws-live",
    "test:openai:mock": "vitest run src/__tests__/openai/openai-runtime.test.ts",
    "test:anthropic:live": "vitest run src/__tests__/providers/anthropic-live",
    "test:anthropic:mock": "vitest run src/__tests__/providers/anthropic",
    "test:gemini:live": "vitest run src/__tests__/providers/gemini-live",
    "test:ai-sdk:live": "vitest run src/__tests__/providers/ai-sdk-live",
    "test:ai-sdk:mock": "vitest run src/__tests__/providers/ai-sdk",
    "test:langchain:live": "vitest run src/__tests__/providers/langchain-live",
    "test:langchain:mock": "vitest run src/__tests__/providers/langchain",
    "test:mcp-provider": "vitest run src/__tests__/providers/mcp",
    "test:mcp-server": "vitest run src/__tests__/mcp-server",
    "test:providers:conformance": "vitest run src/__tests__/providers/conformance",
    "test:conformance": "vitest run src/__tests__/conformance",
    "test:semantic-kernel": "vitest run src/__tests__/providers/semantic-kernel",
    "test:gemini:mock": "vitest run src/__tests__/providers/gemini",
    "test:governance": "vitest run src/__tests__/governance",
    "test:evalops": "vitest run src/__tests__/evalops",
    "test:evidence": "vitest run src/__tests__/evidence",
    "test:provenance": "vitest run src/__tests__/provenance",
    "test:memory": "vitest run src/__tests__/memory",
    "test:audit": "vitest run src/__tests__/audit",
    "test:controls": "vitest run src/__tests__/controls",
    "test:control-plane": "vitest run src/__tests__/control-plane",
    "test:replay": "vitest run src/__tests__/replay",
    "test:security": "vitest run src/__tests__/security",
    "test:security-packs": "vitest run src/__tests__/security-packs",
    "validate": "npm run build --silent && node dist/cli.js validate examples"
  },
