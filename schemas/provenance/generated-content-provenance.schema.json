{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicf.dev/schemas/provenance/generated-content-provenance.schema.json",
  "title": "AICF Generated Content Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contentId",
    "contentType",
    "generatedBy",
    "providerRefs",
    "modelRefs",
    "capabilityRefs",
    "sourceRefs",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "contentId": { "type": "string", "minLength": 1 },
    "contentType": { "enum": ["text", "document", "image", "audio", "video", "other"] },
    "generatedBy": {
      "enum": ["model", "model_assisted_human", "human_approved_model"]
    },
    "providerRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/provider_ref" }
    },
    "modelRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "capabilityRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability_ref" }
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_ref" }
    },
    "approvalRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "traceRef": { "$ref": "#/$defs/trace_ref" },
    "createdAt": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "capability_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilityId"],
      "properties": {
        "capabilityId": { "type": "string", "minLength": 1 },
        "operation": { "enum": ["select", "read", "prepare", "commit", "verify"] },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "provider_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerId"],
      "properties": {
        "providerId": { "type": "string", "minLength": 1 },
        "requestId": { "type": "string", "minLength": 1 },
        "responseId": { "type": "string", "minLength": 1 },
        "runId": { "type": "string", "minLength": 1 },
        "traceId": { "type": "string", "minLength": 1 }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "sourceType", "trust"],
      "properties": {
        "contentHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "freshness": { "enum": ["fresh", "stale", "unknown"] },
        "retrievedAt": { "type": "string", "minLength": 1 },
        "sourceId": { "type": "string", "minLength": 1 },
        "sourceType": {
          "enum": [
            "user_message",
            "uploaded_file",
            "retrieved_document",
            "app_record",
            "tool_result",
            "external_api",
            "policy",
            "manual_review",
            "model_output"
          ]
        },
        "trust": {
          "enum": [
            "system_instruction",
            "developer_instruction",
            "app_policy",
            "app_data",
            "tool_result",
            "retrieved_document",
            "user_input",
            "model_output",
            "external_api"
          ]
        },
        "uri": { "type": "string", "minLength": 1 }
      }
    },
    "trace_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceId"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "traceId": { "type": "string", "minLength": 1 }
      }
    }
  }
}
