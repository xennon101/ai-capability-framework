{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xennon101/ai-capability-framework/main/schemas/governance/lifecycle-transition.schema.json",
  "title": "AICF Governance Lifecycle Transition",
  "type": "object",
  "additionalProperties": false,
  "required": ["capabilityId", "to", "reason"],
  "properties": {
    "capabilityId": { "type": "string", "minLength": 1 },
    "from": { "$ref": "#/$defs/lifecycle_status" },
    "to": { "$ref": "#/$defs/lifecycle_status" },
    "reason": { "type": "string", "minLength": 1 },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "type": { "enum": ["user", "service", "system"] }
      }
    },
    "override": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "approvedBy": { "type": "string" },
        "emergency": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    }
  },
  "$defs": {
    "lifecycle_status": {
      "enum": [
        "draft",
        "review",
        "approved",
        "canary",
        "production",
        "deprecated",
        "disabled",
        "removed"
      ]
    }
  }
}
