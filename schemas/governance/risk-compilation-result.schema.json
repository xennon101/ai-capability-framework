{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xennon101/ai-capability-framework/main/schemas/governance/risk-compilation-result.schema.json",
  "title": "AICF Governance Risk Compilation Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["capabilityId", "declaredRiskTier", "inferredMinimumRiskTier", "passed", "reasons", "warnings", "requiredControls"],
  "properties": {
    "capabilityId": { "type": "string" },
    "declaredRiskTier": { "$ref": "#/$defs/risk_tier" },
    "inferredMinimumRiskTier": { "$ref": "#/$defs/risk_tier" },
    "passed": { "type": "boolean" },
    "reasons": { "type": "array", "items": { "$ref": "#/$defs/reason" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/reason" } },
    "requiredControls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "present", "required"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "present": { "type": "boolean" },
          "required": { "type": "boolean" }
        }
      }
    }
  },
  "$defs": {
    "risk_tier": { "enum": ["none", "low", "medium", "high", "critical"] },
    "reason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "enum": ["info", "warning", "blocking"] }
      }
    }
  }
}
