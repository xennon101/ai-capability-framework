{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xennon101/ai-capability-framework/main/schemas/security-packs/security-case-suite.schema.json",
  "title": "AICF Security Case Suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generatedAt", "cases"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "packId",
          "capabilityId",
          "capabilityType",
          "riskTier",
          "name",
          "userMessage",
          "expected",
          "tags"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "packId": { "type": "string", "minLength": 1 },
          "capabilityId": { "type": "string", "minLength": 1 },
          "capabilityType": { "type": "string", "minLength": 1 },
          "riskTier": { "enum": ["none", "low", "medium", "high", "critical"] },
          "name": { "type": "string", "minLength": 1 },
          "userMessage": { "type": "string", "minLength": 1 },
          "expected": { "type": "object" },
          "tags": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
