{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xennon101/ai-capability-framework/main/schemas/conformance/conformance-case.schema.json",
  "title": "AICF Provider Conformance Case",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "input", "capabilityIds", "expected"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "input": { "type": "string", "minLength": 1 },
    "provider": {
      "type": "string",
      "enum": ["openai", "anthropic", "gemini", "ai-sdk", "mcp", "langchain", "semantic-kernel-mcp", "semantic-kernel-openapi"]
    },
    "capabilityIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "mockProviderResponses": {
      "type": "array",
      "items": {}
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providerToolNames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resultStatuses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["success", "approval_required", "denied", "failed", "validation_error", "unavailable"]
          }
        },
        "finalTextRequiredSubstrings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "canonicalToolCalls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["capabilityId"],
            "properties": {
              "capabilityId": { "type": "string", "minLength": 1 },
              "argsSubset": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    }
  }
}
