{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicf.dev/schemas/aws/approval-task.schema.json",
  "title": "AICF AWS Step Functions Approval Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "createdAt",
    "preparedActionId",
    "schemaVersion",
    "status",
    "taskId",
    "updatedAt"
  ],
  "properties": {
    "approvalRecordId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "executionArn": { "type": "string" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "heartbeatSeconds": { "type": "integer", "minimum": 1 },
    "payloadHash": { "type": "string" },
    "preparedActionId": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": "1.0" },
    "status": { "enum": ["started", "approved", "rejected", "expired", "cancelled"] },
    "taskId": { "type": "string", "minLength": 1 },
    "taskTokenHash": { "type": "string" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
