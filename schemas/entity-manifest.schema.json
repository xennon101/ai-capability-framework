{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xennon101/ai-capability-framework/main/schemas/entity-manifest.schema.json",
  "title": "AICF Entity Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "name",
    "summary",
    "canonical_id",
    "data_classification",
    "lookup",
    "allowed_actions",
    "model_guidance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9_]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-.]+)?(?:\\+[0-9A-Za-z-.]+)?$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "canonical_id": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "pattern": { "type": "string" }
      }
    },
    "data_classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default"],
      "properties": {
        "default": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "target_entity", "cardinality"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "target_entity": { "type": "string", "minLength": 1 },
          "cardinality": {
            "enum": ["one_to_one", "one_to_many", "many_to_one", "many_to_many"]
          },
          "lookup_capability": { "type": "string" }
        }
      }
    },
    "lookup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_capability"],
      "properties": {
        "primary_capability": { "type": "string" }
      }
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "model_guidance": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object"
    }
  }
}
