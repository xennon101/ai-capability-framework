{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xennon101/ai-capability-framework/main/schemas/eval-case.schema.json",
  "title": "AICF Eval Case",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "input", "expected", "scorers"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    "name": {
      "type": "string"
    },
    "capability_under_test": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_message"],
      "properties": {
        "user_message": { "type": "string", "minLength": 1 },
        "conversation": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "content"],
            "properties": {
              "role": { "enum": ["user", "assistant", "system", "tool"] },
              "content": { "type": "string" }
            }
          }
        }
      }
    },
    "context": {
      "type": "object"
    },
    "expected": { "$ref": "#/$defs/expected_behavior" },
    "scorers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "minLength": 1 }
        }
      }
    },
    "extensions": {
      "type": "object"
    }
  },
  "$defs": {
    "expected_behavior": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "selected_capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "includes": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "excludes": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "tool_calls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["capability_id"],
            "properties": {
              "capability_id": { "type": "string", "minLength": 1 },
              "args_match": { "type": "object" },
              "args_exact": { "type": "object" },
              "allowed_fields": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "forbidden_tool_calls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["capability_id"],
            "properties": {
              "capability_id": { "type": "string", "minLength": 1 }
            }
          }
        },
        "tool_call_sequence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "policy_decision": {
          "enum": ["allowed", "approval_required", "denied"]
        },
        "action_state": {
          "enum": [
            "none",
            "prepared",
            "approval_required",
            "committed",
            "denied",
            "refused"
          ]
        },
        "no_commit": { "type": "boolean" },
        "refusal": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required"],
          "properties": {
            "required": { "type": "boolean" },
            "reason_contains": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "response": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "must_include": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "must_not_include": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
