{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicf.dev/schemas/evalops/openai-eval-dataset.schema.json",
  "title": "AICF OpenAI Eval Dataset Export",
  "type": "object",
  "additionalProperties": false,
  "required": ["data", "schemaVersion", "source"],
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "input", "metadata"],
        "properties": {
          "expected": { "type": "object" },
          "id": { "type": "string", "minLength": 1 },
          "input": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["content", "role"],
              "properties": {
                "content": { "type": "string" },
                "role": { "const": "user" }
              }
            }
          },
          "metadata": { "type": "object" }
        }
      }
    },
    "schemaVersion": { "const": "1.0" },
    "source": { "const": "aicf" }
  }
}
