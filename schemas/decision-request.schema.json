{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xennon101/ai-capability-framework/main/schemas/decision-request.schema.json",
  "title": "AICF Decision Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["capabilityId", "operation", "context"],
  "properties": {
    "capabilityId": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "enum": ["select", "prepare", "commit"]
    },
    "args": {
      "type": "object"
    },
    "context": {
      "$ref": "#/$defs/adapter_context"
    },
    "facts": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "type": "boolean" },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["value"],
            "properties": {
              "value": { "type": "boolean" },
              "reason": { "type": "string" }
            }
          }
        ]
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved"],
      "properties": {
        "approved": { "type": "boolean" },
        "approvalId": { "type": "string", "minLength": 1 }
      }
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "adapter_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["autonomyTier", "permissions"],
      "properties": {
        "autonomyTier": {
          "enum": ["A0", "A1", "A2", "A3", "A4", "A5"]
        },
        "permissions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tenantId": {
          "type": "string",
          "minLength": 1
        },
        "userId": {
          "type": "string",
          "minLength": 1
        },
        "riskCeiling": {
          "enum": ["none", "low", "medium", "high", "critical"]
        },
        "allowedRiskTiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["none", "low", "medium", "high", "critical"]
          }
        }
      }
    }
  }
}
